# ----------------------------------------------------------------------------
# Adaptive Booth API — runtime configuration template (NO real secrets here).
# Copy to `.env` and fill in real values:   cp .env.example .env
# `.env` is git/.docker-ignored and never baked into the image.
# ----------------------------------------------------------------------------

# API key clients must send in the `Authentication-API-Key` request header.
AUTHENTICATION_API_KEY=

# Roboflow model API keys.
#   - hall key is required by /hall_with_booth_predict
#   - icon + trail keys are required by /predict and /debug_predict
# Models load lazily, so /pdf_booth_predict works even if these are blank.
ROBOFLOW_ICON_API_KEY=
ROBOFLOW_TRAIL_API_KEY=
ROBOFLOW_HALL_API_KEY=

# Keep S3 writeback OFF. docker-compose.yml also force-overrides this to "false".
S3_WRITEBACK_ENABLED=false

# Long edge (px) of the raster sent to the Roboflow hall model. Hall boxes are
# scaled back up into the full booth-render space for grouping.
HALL_RASTER_MAX_EDGE=2048

# Persist each request's input + JSON result under /data (audit trail).
PERSIST_EXECUTIONS=true
